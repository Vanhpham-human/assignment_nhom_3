<%- include('partials/header') %>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/dashboard/overview" class="row g-3 align-items-end">
      <div class="col-md-2">
        <label class="form-label">Preset</label>
        <select class="form-select" name="preset">
          <option value="thisMonth" <%= filters.preset === 'thisMonth' ? 'selected' : '' %>>Tháng này</option>
          <option value="lastMonth" <%= filters.preset === 'lastMonth' ? 'selected' : '' %>>Tháng trước</option>
          <option value="6months" <%= filters.preset === '6months' ? 'selected' : '' %>>6 tháng gần đây</option>
          <option value="custom" <%= filters.preset === 'custom' ? 'selected' : '' %>>Tùy chỉnh</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Từ ngày</label>
        <input type="date" class="form-control" name="startDate" value="<%= filters.startDate %>" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Đến ngày</label>
        <input type="date" class="form-control" name="endDate" value="<%= filters.endDate %>" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Nhóm theo</label>
        <select class="form-select" name="groupBy">
          <option value="month" <%= filters.groupBy === 'month' ? 'selected' : '' %>>Tháng</option>
          <option value="day" <%= filters.groupBy === 'day' ? 'selected' : '' %>>Ngày</option>
        </select>
      </div>
      <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">Lọc dữ liệu</button>
      </div>
    </form>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h6 class="text-muted">Tổng doanh thu</h6>
        <h4><%= formatCurrency(chartData.netProfit.totalRevenue) %> VND</h4>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h6 class="text-muted">Tổng giá vốn</h6>
        <h4><%= formatCurrency(chartData.netProfit.totalCost) %> VND</h4>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h6 class="text-muted">Lợi nhuận ròng</h6>
        <h4 class="text-success"><%= formatCurrency(chartData.netProfit.netProfit) %> VND</h4>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card shadow-sm">
      <div class="card-header bg-white fw-semibold">Doanh thu theo thời gian</div>
      <div class="card-body">
        <canvas id="revenueLineChart" height="120"></canvas>
      </div>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="card shadow-sm">
      <div class="card-header bg-white fw-semibold">Doanh thu theo danh mục</div>
      <div class="card-body">
        <canvas id="categoryBarChart" height="120"></canvas>
      </div>
    </div>
  </div>
</div>

<script>
  const revenueByTime = <%- JSON.stringify(chartData.revenueByTime) %>;
  const revenueByCategory = <%- JSON.stringify(chartData.revenueByCategory) %>;

  new Chart(document.getElementById('revenueLineChart'), {
    type: 'line',
    data: {
      labels: revenueByTime.map((item) => item.label),
      datasets: [
        {
          label: 'Doanh thu (VND)',
          data: revenueByTime.map((item) => item.totalRevenue),
          borderColor: '#0d6efd',
          backgroundColor: 'rgba(13, 110, 253, 0.2)',
          tension: 0.3,
          fill: true
        }
      ]
    }
  });

  new Chart(document.getElementById('categoryBarChart'), {
    type: 'bar',
    data: {
      labels: revenueByCategory.map((item) => item._id),
      datasets: [
        {
          label: 'Doanh thu (VND)',
          data: revenueByCategory.map((item) => item.revenue),
          backgroundColor: '#198754'
        }
      ]
    },
    options: {
      indexAxis: 'y'
    }
  });
</script>

<%- include('partials/footer') %>
