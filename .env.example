# Same host as Compass: mongodb://localhost:27017/
# If you omit the database name, the app uses database "trello_boards".
MONGODB_URI=mongodb://localhost:27017/
# API Express (mặc định 3000 nếu không khai báo)
API_PORT=3000
JWT_SECRET=your-long-random-secret-for-production

# Optional: if you run "npm run build" + static server (no proxy), set before build:
# REACT_APP_API_URL=http://localhost:3000
# Optional: proxy target for "npm start" (default http://127.0.0.1:3000)
# REACT_APP_PROXY_TARGET=http://127.0.0.1:3000
